# Copy this file to `.env` and set POSTGRES_PASSWORD before running.
# `.env` is gitignored; this example is not.

API_BASE=http://localhost
PUBLIC_SITE_URL=http://localhost:5173

# Origins allowed to open the WebSocket and make state-changing API calls
# (comma-separated). This is the CSRF / cross-site-WebSocket-hijacking allowlist:
# a browser request whose Origin is not listed here is rejected. Includes both
# local stacks by default; in production set it to your real site origin, e.g.
# https://yourapp.com. If left empty the check fails OPEN (allows all) with a
# startup warning, so a misconfigured deploy degrades to "no origin check" rather
# than "nobody can connect".
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Development stack (docker-compose.yaml) ---
FRONTEND_HOST=frontend-c
FRONTEND_PORT=5173

BACKEND_HOST=server-c
BACKEND_PORT=3000

POSTGRES_HOST=postgres-c
POSTGRES_PORT=5432
POSTGRES_USER=postgre
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=info_db

# --- Production stack (docker-compose.prod.yaml) ---
# The only host port the production stack publishes. nginx serves the built
# frontend here and proxies /api + /ws to the backend over the internal network.
PROD_PORT=8080

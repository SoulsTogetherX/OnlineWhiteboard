# Copy this file to `.env` and set POSTGRES_PASSWORD before running.
# `.env` is gitignored; this example is not.

API_BASE=http://localhost
PUBLIC_SITE_URL=http://localhost:5173

# Origins allowed to open the WebSocket and make state-changing API calls
# (comma-separated). This is the CSRF / cross-site-WebSocket-hijacking allowlist:
# a browser request whose Origin is not listed here is rejected. Includes both
# local stacks by default; in production set it to your real site origin, e.g.
# https://yourapp.com. If left empty the check fails OPEN (allows all) with a
# startup warning, so a misconfigured deploy degrades to "no origin check" rather
# than "nobody can connect".
#
# The 127.0.0.1 entries are NOT redundant with the localhost ones. An Origin is
# matched as a STRING, so http://127.0.0.1:8080 and http://localhost:8080 are
# different origins even though they reach the same server. On a Windows host
# `localhost` can resolve to IPv6 ::1 where the published port refuses (§9), which
# leaves 127.0.0.1 as the only address a browser can actually load the app from —
# and without it listed, the page renders but every WebSocket upgrade is rejected
# and the UI just says "Offline".
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080

# --- Development stack (docker-compose.yaml) ---
FRONTEND_HOST=frontend-c
FRONTEND_PORT=5173

BACKEND_HOST=server-c
BACKEND_PORT=3000

POSTGRES_HOST=postgres-c
POSTGRES_PORT=5432
POSTGRES_USER=postgre
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=info_db

# --- Production stack (docker-compose.prod.yaml) ---
# The only host port the production stack publishes. nginx serves the built
# frontend here and proxies /api + /ws to the backend over the internal network.
PROD_PORT=8080

# Email-at-rest secrets. BOTH must be set in production or the server refuses to
# start (see backend/src/auth/emailCrypto.ts). In development, insecure built-in
# defaults are used with a loud warning so a fresh clone still runs.
#
# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# They are deliberately SEPARATE secrets: the pepper never decrypts anything and
# the key never helps you search, so leaking one does not give both capabilities.
EMAIL_INDEX_PEPPER=<generate me>
EMAIL_ENCRYPTION_KEY=<generate me>
